  body { font-family: Calibri, sans-serif; font-size: 11pt; }
  h1 { font-size: 24pt; color: #2F5496; }
  h2 { font-size: 18pt; color: #2F5496; border-bottom: 1px solid #2F5496; padding-bottom: 2px; margin-top: 24px;}
  h3 { font-size: 14pt; color: #1F3763; margin-top: 16px;}
  table { border-collapse: collapse; width: 100%; border: 1px solid black; margin-top: 12px; margin-bottom: 12px;}
  th, td { border: 1px solid black; padding: 8px; text-align: left; }
